<?xml version="1.0" encoding="utf-8" ?>
<ResourceDictionary xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!-- ═══════════════════════════════════════════════════════════ -->
    <!--                   LIQUID GLASS DESIGN SYSTEM                 -->
    <!--                   Dark High-Contrast Theme                   -->
    <!-- ═══════════════════════════════════════════════════════════ -->

    <!-- 🎨 COLOR PALETTE -->
    <Color x:Key="GlassBackground">#0F1923</Color>
    <Color x:Key="GlassSurface">#1A2535</Color>
    <Color x:Key="GlassSurfaceAlt">#1E2D40</Color>
    <Color x:Key="GlassPrimary">#7C9EFF</Color>
    <Color x:Key="GlassSecondary">#9B6FD4</Color>
    <Color x:Key="GlassAccent">#F093FB</Color>
    <Color x:Key="GlassSuccess">#2ECC71</Color>
    <Color x:Key="GlassWarning">#F39C12</Color>
    <Color x:Key="GlassDanger">#E74C3C</Color>
    <Color x:Key="GlassText">#ECF0F1</Color>
    <Color x:Key="GlassTextLight">#95A5A6</Color>
    <Color x:Key="GlassBorder">#2C3E50</Color>

    <!-- 🌈 GRADIENT BRUSHES -->
    <LinearGradientBrush x:Key="PrimaryGradient" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#5C7CFA" Offset="0.0"/>
        <GradientStop Color="#9B6FD4" Offset="1.0"/>
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="SuccessGradient" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#27AE60" Offset="0.0"/>
        <GradientStop Color="#1E8449" Offset="1.0"/>
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="DangerGradient" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#E74C3C" Offset="0.0"/>
        <GradientStop Color="#C0392B" Offset="1.0"/>
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="WarningGradient" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#F39C12" Offset="0.0"/>
        <GradientStop Color="#D68910" Offset="1.0"/>
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="InfoGradient" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#2980B9" Offset="0.0"/>
        <GradientStop Color="#5C7CFA" Offset="1.0"/>
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="BackgroundGradient" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#0F1923" Offset="0.0"/>
        <GradientStop Color="#1A2535" Offset="0.5"/>
        <GradientStop Color="#0F1923" Offset="1.0"/>
    </LinearGradientBrush>

    <!-- 💎 GLASS CARD STYLE -->
    <Style x:Key="GlassCard" TargetType="Border">
        <Setter Property="BackgroundColor" Value="{StaticResource GlassSurface}"/>
        <Setter Property="StrokeThickness" Value="1"/>
        <Setter Property="Stroke" Value="{StaticResource GlassBorder}"/>
        <Setter Property="Shadow">
            <Setter.Value>
                <Shadow Brush="#805C7CFA" Offset="0,8" Radius="24" Opacity="0.4"/>
            </Setter.Value>
        </Setter>
        <Setter Property="StrokeShape">
            <Setter.Value>
                <RoundRectangle CornerRadius="24"/>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- 🔮 GLASS BUTTON STYLE -->
    <Style x:Key="GlassButton" TargetType="Button">
        <Setter Property="BackgroundColor" Value="#2C3E50"/>
        <Setter Property="TextColor" Value="{StaticResource GlassText}"/>
        <Setter Property="FontFamily" Value="AvantGardeDemi"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="Padding" Value="20,12"/>
        <Setter Property="CornerRadius" Value="16"/>
        <Setter Property="Shadow">
            <Setter.Value>
                <Shadow Brush="#605C7CFA" Offset="0,4" Radius="12" Opacity="0.4"/>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ✨ GLASS BUTTON PRIMARY -->
    <Style x:Key="GlassButtonPrimary" TargetType="Button" BasedOn="{StaticResource GlassButton}">
        <Setter Property="Background" Value="{StaticResource PrimaryGradient}"/>
        <Setter Property="TextColor" Value="White"/>
        <Setter Property="Shadow">
            <Setter.Value>
                <Shadow Brush="#805C7CFA" Offset="0,6" Radius="16" Opacity="0.5"/>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- 🌟 GLASS BUTTON SUCCESS -->
    <Style x:Key="GlassButtonSuccess" TargetType="Button" BasedOn="{StaticResource GlassButton}">
        <Setter Property="Background" Value="{StaticResource SuccessGradient}"/>
        <Setter Property="TextColor" Value="White"/>
    </Style>

    <!-- 🔥 GLASS BUTTON DANGER -->
    <Style x:Key="GlassButtonDanger" TargetType="Button" BasedOn="{StaticResource GlassButton}">
        <Setter Property="Background" Value="{StaticResource DangerGradient}"/>
        <Setter Property="TextColor" Value="White"/>
    </Style>

    <!-- ⚡ GLASS BUTTON WARNING -->
    <Style x:Key="GlassButtonWarning" TargetType="Button" BasedOn="{StaticResource GlassButton}">
        <Setter Property="Background" Value="{StaticResource WarningGradient}"/>
        <Setter Property="TextColor" Value="White"/>
    </Style>

    <!-- 💬 GLASS ENTRY STYLE -->
    <Style x:Key="GlassEntry" TargetType="Entry">
        <Setter Property="BackgroundColor" Value="#253545"/>
        <Setter Property="TextColor" Value="{StaticResource GlassText}"/>
        <Setter Property="PlaceholderColor" Value="{StaticResource GlassTextLight}"/>
        <Setter Property="FontFamily" Value="AvantGardeBook"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="HeightRequest" Value="48"/>
    </Style>

    <!-- 🏷️ GLASS LABEL TITLE -->
    <Style x:Key="GlassTitleLabel" TargetType="Label">
        <Setter Property="FontFamily" Value="AvantGardeBold"/>
        <Setter Property="FontSize" Value="24"/>
        <Setter Property="TextColor" Value="{StaticResource GlassText}"/>
    </Style>

    <!-- 📝 GLASS LABEL SUBTITLE -->
    <Style x:Key="GlassSubtitleLabel" TargetType="Label">
        <Setter Property="FontFamily" Value="AvantGardeDemi"/>
        <Setter Property="FontSize" Value="16"/>
        <Setter Property="TextColor" Value="{StaticResource GlassText}"/>
    </Style>

    <!-- 📄 GLASS LABEL BODY -->
    <Style x:Key="GlassBodyLabel" TargetType="Label">
        <Setter Property="FontFamily" Value="AvantGardeBook"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="TextColor" Value="{StaticResource GlassTextLight}"/>
    </Style>

    <!-- 🎯 GLASS BADGE STYLE -->
    <Style x:Key="GlassBadge" TargetType="Border">
        <Setter Property="BackgroundColor" Value="#253545"/>
        <Setter Property="StrokeThickness" Value="1"/>
        <Setter Property="Stroke" Value="{StaticResource GlassBorder}"/>
        <Setter Property="Padding" Value="12,6"/>
        <Setter Property="StrokeShape">
            <Setter.Value>
                <RoundRectangle CornerRadius="12"/>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- 🔔 GLASS INFO PANEL -->
    <Style x:Key="GlassInfoPanel" TargetType="Border">
        <Setter Property="BackgroundColor" Value="#1A2D45"/>
        <Setter Property="StrokeThickness" Value="1"/>
        <Setter Property="Stroke" Value="#5C7CFA"/>
        <Setter Property="Padding" Value="16"/>
        <Setter Property="Shadow">
            <Setter.Value>
                <Shadow Brush="#605C7CFA" Offset="0,4" Radius="12" Opacity="0.3"/>
            </Setter.Value>
        </Setter>
        <Setter Property="StrokeShape">
            <Setter.Value>
                <RoundRectangle CornerRadius="16"/>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ✅ GLASS SUCCESS PANEL -->
    <Style x:Key="GlassSuccessPanel" TargetType="Border" BasedOn="{StaticResource GlassInfoPanel}">
        <Setter Property="BackgroundColor" Value="#1A3A2A"/>
        <Setter Property="Stroke" Value="#27AE60"/>
    </Style>

    <!-- ⚠️ GLASS WARNING PANEL -->
    <Style x:Key="GlassWarningPanel" TargetType="Border" BasedOn="{StaticResource GlassInfoPanel}">
        <Setter Property="BackgroundColor" Value="#2E2510"/>
        <Setter Property="Stroke" Value="#F39C12"/>
    </Style>

    <!-- 🎨 GLASS STATS CARD -->
    <Style x:Key="GlassStatsCard" TargetType="Border">
        <Setter Property="BackgroundColor" Value="{StaticResource GlassSurfaceAlt}"/>
        <Setter Property="StrokeThickness" Value="1"/>
        <Setter Property="Stroke" Value="{StaticResource GlassBorder}"/>
        <Setter Property="Padding" Value="16"/>
        <Setter Property="Shadow">
            <Setter.Value>
                <Shadow Brush="#405C7CFA" Offset="0,2" Radius="8" Opacity="0.3"/>
            </Setter.Value>
        </Setter>
        <Setter Property="StrokeShape">
            <Setter.Value>
                <RoundRectangle CornerRadius="16"/>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
