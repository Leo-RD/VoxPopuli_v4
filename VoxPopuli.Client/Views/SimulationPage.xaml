<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:skia="clr-namespace:SkiaSharp.Views.Maui.Controls;assembly=SkiaSharp.Views.Maui.Controls"
             x:Class="VoxPopuli.Client.Views.SimulationPage"
             Title="VoxPopuli 4.0">

    <!-- 🌈 LIQUID GLASS BACKGROUND -->
    <ContentPage.Background>
        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#E0E7FF" Offset="0.0"/>
            <GradientStop Color="#FEE2F8" Offset="0.5"/>
            <GradientStop Color="#DBEAFE" Offset="1.0"/>
        </LinearGradientBrush>
    </ContentPage.Background>

    <Grid RowDefinitions="*" Padding="20">

        <!-- 💎 MAIN GLASS CONTAINER -->
        <Border Grid.Row="0"
                Style="{StaticResource GlassCard}"
                Padding="0">

            <Grid RowDefinitions="Auto, *">

                <!-- ✨ HEADER BAR (LIQUID GLASS) -->
                <Border Grid.Row="0" 
                        Padding="20,16"
                        StrokeThickness="0"
                        BackgroundColor="#F0FFFFFF">
                    <Border.Shadow>
                        <Shadow Brush="#20667EEA" Offset="0,2" Radius="8" Opacity="0.2"/>
                    </Border.Shadow>
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="24,24,0,0"/>
                    </Border.StrokeShape>
                    
                    <Grid ColumnDefinitions="Auto, *, Auto, Auto">
                        <!-- Status Indicator -->
                        <HorizontalStackLayout Grid.Column="0" Spacing="12">
                            <Border WidthRequest="12" HeightRequest="12" 
                                    BackgroundColor="#4ECDC4"
                                    VerticalOptions="Center">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="6"/>
                                </Border.StrokeShape>
                                <Border.Shadow>
                                    <Shadow Brush="#4ECDC4" Offset="0,0" Radius="8" Opacity="0.6"/>
                                </Border.Shadow>
                            </Border>
                            <Label Text="Simulation Active" 
                                   Style="{StaticResource GlassSubtitleLabel}"
                                   VerticalOptions="Center"/>
                        </HorizontalStackLayout>

                        <!-- Running Badge -->
                        <Border Grid.Column="2" 
                                Padding="12,6" 
                                Margin="0,0,12,0"
                                StrokeThickness="0"
                                VerticalOptions="Center">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Color="#4ECDC4" Offset="0.0"/>
                                    <GradientStop Color="#44A08D" Offset="1.0"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="12"/>
                            </Border.StrokeShape>
                            <Border.Shadow>
                                <Shadow Brush="#404ECDC4" Offset="0,4" Radius="12" Opacity="0.3"/>
                            </Border.Shadow>
                            <Label Text="RUNNING" TextColor="White" FontFamily="AvantGardeBold" FontSize="12"/>
                        </Border>

                        <!-- Control Button -->
                        <Button Grid.Column="3" 
                                Text="{Binding SimulationButtonText}" 
                                Style="{StaticResource GlassButtonPrimary}"
                                Padding="20,10"
                                Command="{Binding ToggleSimulationCommand}"/>
                    </Grid>
                </Border>

                <!-- 🎯 MAIN CONTENT AREA -->
                <Grid Grid.Row="1" ColumnDefinitions="2*, *" Padding="20">

                    <!-- 🎨 LEFT: SIMULATION CANVAS -->
                    <VerticalStackLayout Grid.Column="0" Spacing="16" Padding="0,0,16,0">

                        <!-- Canvas Header -->
                        <Grid ColumnDefinitions="*, Auto">
                            <Label Grid.Column="0" 
                                   Text="🌐 Espace de Simulation 2D" 
                                   Style="{StaticResource GlassSubtitleLabel}"
                                   VerticalOptions="Center"/>

                            <!-- Zoom Controls -->
                            <HorizontalStackLayout Grid.Column="1" Spacing="8">
                                <Button Text="+" 
                                        Style="{StaticResource GlassButton}"
                                        FontSize="18"
                                        Padding="16,8" 
                                        CornerRadius="12"
                                        Command="{Binding ZoomInCommand}"/>
                                <Button Text="−" 
                                        Style="{StaticResource GlassButton}"
                                        FontSize="18"
                                        Padding="16,8" 
                                        CornerRadius="12"
                                        Command="{Binding ZoomOutCommand}"/>
                                <Button Text="↺" 
                                        Style="{StaticResource GlassButton}"
                                        FontSize="16"
                                        Padding="16,8" 
                                        CornerRadius="12"
                                        Command="{Binding ResetZoomCommand}"/>
                            </HorizontalStackLayout>
                        </Grid>

                        <!-- 🎮 SIMULATION CANVAS (GLASS CONTAINER) -->
                        <Border Style="{StaticResource GlassCard}" Padding="0">
                            <Grid>
                                <!-- Dark Background for Canvas -->
                                <Border BackgroundColor="#1A1A2E">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="20"/>
                                    </Border.StrokeShape>
                                    <skia:SKCanvasView x:Name="SimulationCanvas"
                                                       HeightRequest="420"
                                                       PaintSurface="OnCanvasPaintSurface"
                                                       EnableTouchEvents="True" />
                                </Border>

                                <!-- 🏷️ LEGEND (FLOATING GLASS) -->
                                <Border Padding="16" 
                                        Margin="16"
                                        VerticalOptions="Start" 
                                        HorizontalOptions="Start"
                                        BackgroundColor="#F5FFFFFF"
                                        StrokeThickness="1"
                                        Stroke="#40FFFFFF">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="16"/>
                                    </Border.StrokeShape>
                                    <Border.Shadow>
                                        <Shadow Brush="#30667EEA" Offset="0,4" Radius="12" Opacity="0.2"/>
                                    </Border.Shadow>
                                    <VerticalStackLayout Spacing="8">
                                        <Label Text="✨ Légende" 
                                               FontFamily="AvantGardeBold" 
                                               FontSize="13" 
                                               TextColor="{StaticResource GlassText}" 
                                               Margin="0,0,0,4"/>
                                        <HorizontalStackLayout Spacing="8">
                                            <Border BackgroundColor="#2ECC71" 
                                                    WidthRequest="16" HeightRequest="16">
                                                <Border.Shadow>
                                                    <Shadow Brush="#2ECC71" Offset="0,0" Radius="6" Opacity="0.5"/>
                                                </Border.Shadow>
                                            </Border>
                                            <Label Text="Content (Aligné)" 
                                                   TextColor="{StaticResource GlassText}" 
                                                   FontFamily="AvantGardeBook" 
                                                   FontSize="12"
                                                   VerticalOptions="Center"/>
                                        </HorizontalStackLayout>
                                        <HorizontalStackLayout Spacing="8">
                                            <Border BackgroundColor="#E74C3C" 
                                                    WidthRequest="16" HeightRequest="16">
                                                <Border.StrokeShape>
                                                    <RoundRectangle CornerRadius="8"/>
                                                </Border.StrokeShape>
                                                <Border.Shadow>
                                                    <Shadow Brush="#E74C3C" Offset="0,0" Radius="6" Opacity="0.5"/>
                                                </Border.Shadow>
                                            </Border>
                                            <Label Text="Pas Content (Opposition)" 
                                                   TextColor="{StaticResource GlassText}" 
                                                   FontFamily="AvantGardeBook" 
                                                   FontSize="12"
                                                   VerticalOptions="Center"/>
                                        </HorizontalStackLayout>
                                        <Label Text="🔴 Vitesse ×2" 
                                               TextColor="#E74C3C" 
                                               FontFamily="AvantGardeDemi" 
                                               FontSize="11" 
                                               Margin="0,4,0,0"/>
                                    </VerticalStackLayout>
                                </Border>

                                <!-- 📊 AGENT COUNT (FLOATING BADGE) -->
                                <Border Margin="16"
                                        Padding="16,12"
                                        VerticalOptions="End" 
                                        HorizontalOptions="End"
                                        StrokeThickness="1">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#F5667EEA" Offset="0.0"/>
                                            <GradientStop Color="#F5764BA2" Offset="1.0"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                    <Border.Stroke>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#80FFFFFF" Offset="0.0"/>
                                            <GradientStop Color="#40FFFFFF" Offset="1.0"/>
                                        </LinearGradientBrush>
                                    </Border.Stroke>
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="16"/>
                                    </Border.StrokeShape>
                                    <Border.Shadow>
                                        <Shadow Brush="#50667EEA" Offset="0,6" Radius="16" Opacity="0.4"/>
                                    </Border.Shadow>
                                    <VerticalStackLayout Spacing="2">
                                        <Label Text="{Binding AgentCount}" 
                                               FontSize="28" 
                                               FontFamily="AvantGardeBold"
                                               TextColor="White"
                                               HorizontalOptions="Center"/>
                                        <Label Text="agents actifs" 
                                               FontSize="11" 
                                               FontFamily="AvantGardeBook"
                                               TextColor="#E0FFFFFF"
                                               HorizontalOptions="Center"/>
                                    </VerticalStackLayout>
                                </Border>
                            </Grid>
                        </Border>

                        <!-- 📈 STATS FOOTER (GLASS) -->
                        <Border BackgroundColor="#F5FFFFFF" 
                                Padding="16,12"
                                StrokeThickness="1"
                                Stroke="#30667EEA">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="16"/>
                            </Border.StrokeShape>
                            <Grid ColumnDefinitions="*, *, *">
                                <Label Grid.Column="0" 
                                       Text="⚡ FPS: 60" 
                                       FontFamily="AvantGardeBook"
                                       FontSize="12" 
                                       TextColor="{StaticResource GlassTextLight}"/>
                                <Label Grid.Column="1" 
                                       Text="⏱️ 00:45" 
                                       FontFamily="AvantGardeBook"
                                       FontSize="12" 
                                       TextColor="{StaticResource GlassTextLight}" 
                                       HorizontalOptions="Center"/>
                                <Label Grid.Column="2" 
                                       Text="🧠 120/s" 
                                       FontFamily="AvantGardeBook"
                                       FontSize="12" 
                                       TextColor="{StaticResource GlassTextLight}" 
                                       HorizontalOptions="End"/>
                            </Grid>
                        </Border>

                    </VerticalStackLayout>

                    <!-- 🎛️ RIGHT: CONTROLS PANEL -->
                    <ScrollView Grid.Column="1">
                        <VerticalStackLayout Spacing="16">

                            <!-- 🎯 AGENT SELECTION (GLASS WARNING PANEL) -->
                            <Border Style="{StaticResource GlassWarningPanel}"
                                    IsVisible="{Binding IsAgentSelected}">
                                <VerticalStackLayout Spacing="12">
                                    <Grid ColumnDefinitions="*, Auto">
                                        <Label Grid.Column="0"
                                               Text="🎯 Agent Sélectionné" 
                                               FontFamily="AvantGardeBold"
                                               FontSize="15" 
                                               TextColor="{StaticResource GlassText}"
                                               VerticalOptions="Center"/>
                                        <Button Grid.Column="1"
                                                Text="✕"
                                                FontSize="18"
                                                FontFamily="AvantGardeBold"
                                                BackgroundColor="Transparent"
                                                TextColor="{StaticResource GlassTextLight}"
                                                Padding="8,4"
                                                Command="{Binding DeselectAgentCommand}"/>
                                    </Grid>
                                    <Label Text="{Binding SelectedAgentInfo}"
                                           Style="{StaticResource GlassBodyLabel}"
                                           LineBreakMode="WordWrap"/>
                                </VerticalStackLayout>
                            </Border>

                            <!-- 💬 POLITICAL PHRASE INPUT (GLASS CARD) -->
                            <Border Style="{StaticResource GlassCard}">
                                <VerticalStackLayout Spacing="12" Padding="16">
                                    <Label Text="💬 Phrase Politique" 
                                           Style="{StaticResource GlassSubtitleLabel}"/>
                                    
                                    <Border BackgroundColor="#F8FFFFFF" 
                                            Padding="12,4"
                                            StrokeThickness="1"
                                            Stroke="#30667EEA">
                                        <Border.StrokeShape>
                                            <RoundRectangle CornerRadius="12"/>
                                        </Border.StrokeShape>
                                        <Entry x:Name="PoliticalPhraseEntry"
                                               Placeholder="Ex: Il faut taxer les richesses..."
                                               Style="{StaticResource GlassEntry}"
                                               HeightRequest="44"
                                               BackgroundColor="Transparent"
                                               Text="{Binding CurrentPoliticalPhrase}"/>
                                    </Border>
                                    
                                    <Button Text="✨ Analyser et Diffuser"
                                            Style="{StaticResource GlassButtonSuccess}"
                                            Command="{Binding AnalyzePhraseCommand}"/>
                                </VerticalStackLayout>
                            </Border>

                            <!-- 🎮 ACTION BUTTONS -->
                            <VerticalStackLayout Spacing="10">
                                <Label Text="⚡ Actions" 
                                       Style="{StaticResource GlassSubtitleLabel}"/>
                                
                                <Button Text="📢 Diffuser Message A"
                                        Style="{StaticResource GlassButtonPrimary}"
                                        Command="{Binding TriggerEventCommand}"/>

                                <Button Text="📣 Diffuser Message B" 
                                        Style="{StaticResource GlassButtonPrimary}"
                                        Command="{Binding BroadcastMessageBCommand}"/>

                                <Button Text="🧠 Inférence ML.NET" 
                                        Style="{StaticResource GlassButtonPrimary}"
                                        Command="{Binding RunInferenceCommand}"/>

                                <Button Text="⚙️ Paramètres" 
                                        Style="{StaticResource GlassButton}"
                                        Command="{Binding NavigateToSettingsCommand}"/>

                                <Button Text="↺ Réinitialiser" 
                                        Style="{StaticResource GlassButton}"
                                        Command="{Binding ResetSimulationCommand}"/>

                                <Button Text="📢 Événement" 
                                        Style="{StaticResource GlassButtonWarning}"
                                        Command="{Binding TriggerEventCommand}"/>
                            </VerticalStackLayout>

                            <!-- 📊 STATS SECTION (GLASS CARDS) -->
                            <VerticalStackLayout Spacing="12">
                                <Label Text="📊 Statistiques" 
                                       Style="{StaticResource GlassSubtitleLabel}"/>

                                <!-- Groupe A Stats -->
                                <Border Style="{StaticResource GlassStatsCard}">
                                    <Border.Stroke>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                            <GradientStop Color="#60667EEA" Offset="0.0"/>
                                            <GradientStop Color="#40667EEA" Offset="1.0"/>
                                        </LinearGradientBrush>
                                    </Border.Stroke>
                                    <VerticalStackLayout Spacing="8">
                                        <HorizontalStackLayout Spacing="8">
                                            <Border BackgroundColor="#667EEA" 
                                                    WidthRequest="8" HeightRequest="8" 
                                                    VerticalOptions="Center">
                                                <Border.StrokeShape>
                                                    <RoundRectangle CornerRadius="4"/>
                                                </Border.StrokeShape>
                                                <Border.Shadow>
                                                    <Shadow Brush="#667EEA" Offset="0,0" Radius="4" Opacity="0.6"/>
                                                </Border.Shadow>
                                            </Border>
                                            <Label Text="Groupe A" 
                                                   FontFamily="AvantGardeDemi"
                                                   FontSize="14" 
                                                   TextColor="#667EEA"/>
                                        </HorizontalStackLayout>
                                        <Grid ColumnDefinitions="*, Auto">
                                            <Label Grid.Column="0" 
                                                   Text="✓ Accord" 
                                                   Style="{StaticResource GlassBodyLabel}"/>
                                            <Label Grid.Column="1" 
                                                   Text="65%" 
                                                   FontFamily="AvantGardeBold" 
                                                   FontSize="14" 
                                                   TextColor="{StaticResource GlassText}"/>
                                        </Grid>
                                        <Grid ColumnDefinitions="*, Auto">
                                            <Label Grid.Column="0" 
                                                   Text="✗ Rejet" 
                                                   Style="{StaticResource GlassBodyLabel}"/>
                                            <Label Grid.Column="1" 
                                                   Text="35%" 
                                                   FontFamily="AvantGardeBold" 
                                                   FontSize="14" 
                                                   TextColor="{StaticResource GlassText}"/>
                                        </Grid>
                                    </VerticalStackLayout>
                                </Border>

                                <!-- Groupe B Stats -->
                                <Border Style="{StaticResource GlassStatsCard}">
                                    <Border.Stroke>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                            <GradientStop Color="#60764BA2" Offset="0.0"/>
                                            <GradientStop Color="#40764BA2" Offset="1.0"/>
                                        </LinearGradientBrush>
                                    </Border.Stroke>
                                    <VerticalStackLayout Spacing="8">
                                        <HorizontalStackLayout Spacing="8">
                                            <Border BackgroundColor="#764BA2" 
                                                    WidthRequest="8" HeightRequest="8" 
                                                    VerticalOptions="Center">
                                                <Border.StrokeShape>
                                                    <RoundRectangle CornerRadius="4"/>
                                                </Border.StrokeShape>
                                                <Border.Shadow>
                                                    <Shadow Brush="#764BA2" Offset="0,0" Radius="4" Opacity="0.6"/>
                                                </Border.Shadow>
                                            </Border>
                                            <Label Text="Groupe B" 
                                                   FontFamily="AvantGardeDemi"
                                                   FontSize="14" 
                                                   TextColor="#764BA2"/>
                                        </HorizontalStackLayout>
                                        <Grid ColumnDefinitions="*, Auto">
                                            <Label Grid.Column="0" 
                                                   Text="✓ Accord" 
                                                   Style="{StaticResource GlassBodyLabel}"/>
                                            <Label Grid.Column="1" 
                                                   Text="42%" 
                                                   FontFamily="AvantGardeBold" 
                                                   FontSize="14" 
                                                   TextColor="{StaticResource GlassText}"/>
                                        </Grid>
                                        <Grid ColumnDefinitions="*, Auto">
                                            <Label Grid.Column="0" 
                                                   Text="✗ Rejet" 
                                                   Style="{StaticResource GlassBodyLabel}"/>
                                            <Label Grid.Column="1" 
                                                   Text="58%" 
                                                   FontFamily="AvantGardeBold" 
                                                   FontSize="14" 
                                                   TextColor="{StaticResource GlassText}"/>
                                        </Grid>
                                    </VerticalStackLayout>
                                </Border>
                            </VerticalStackLayout>

                            <!-- 💌 MESSAGES (GLASS INFO PANEL) -->
                            <Border Style="{StaticResource GlassInfoPanel}">
                                <VerticalStackLayout Spacing="12">
                                    <Label Text="💌 Messages" 
                                           Style="{StaticResource GlassSubtitleLabel}"/>
                                    
                                    <VerticalStackLayout Spacing="10">
                                        <HorizontalStackLayout Spacing="10">
                                            <Border BackgroundColor="#667EEA" 
                                                    WidthRequest="32" HeightRequest="32" 
                                                    VerticalOptions="Start">
                                                <Border.StrokeShape>
                                                    <RoundRectangle CornerRadius="16"/>
                                                </Border.StrokeShape>
                                                <Border.Shadow>
                                                    <Shadow Brush="#667EEA" Offset="0,2" Radius="8" Opacity="0.3"/>
                                                </Border.Shadow>
                                                <Label Text="A" 
                                                       TextColor="White" 
                                                       FontFamily="AvantGardeBold" 
                                                       FontSize="16"
                                                       HorizontalOptions="Center"
                                                       VerticalOptions="Center"/>
                                            </Border>
                                            <Label Text="Message politique pour..."
                                                   Style="{StaticResource GlassBodyLabel}"
                                                   VerticalOptions="Center"
                                                   LineBreakMode="WordWrap"/>
                                        </HorizontalStackLayout>

                                        <HorizontalStackLayout Spacing="10">
                                            <Border BackgroundColor="#764BA2" 
                                                    WidthRequest="32" HeightRequest="32" 
                                                    VerticalOptions="Start">
                                                <Border.StrokeShape>
                                                    <RoundRectangle CornerRadius="16"/>
                                                </Border.StrokeShape>
                                                <Border.Shadow>
                                                    <Shadow Brush="#764BA2" Offset="0,2" Radius="8" Opacity="0.3"/>
                                                </Border.Shadow>
                                                <Label Text="B" 
                                                       TextColor="White" 
                                                       FontFamily="AvantGardeBold" 
                                                       FontSize="16"
                                                       HorizontalOptions="Center"
                                                       VerticalOptions="Center"/>
                                            </Border>
                                            <Label Text="Alternative message..."
                                                   Style="{StaticResource GlassBodyLabel}"
                                                   VerticalOptions="Center"
                                                   LineBreakMode="WordWrap"/>
                                        </HorizontalStackLayout>
                                    </VerticalStackLayout>
                                </VerticalStackLayout>
                            </Border>

                        </VerticalStackLayout>
                    </ScrollView>

                </Grid>

            </Grid>
        </Border>

    </Grid>

</ContentPage>
