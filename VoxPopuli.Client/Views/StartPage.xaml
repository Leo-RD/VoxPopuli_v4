<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:converters="clr-namespace:VoxPopuli.Client.Converters"
             x:Class="VoxPopuli.Client.Views.StartPage"
             Title="VoxPopuli 4.0 - Configuration"
             BackgroundColor="#0F1923">

    <ContentPage.Resources>
        <ResourceDictionary>
            <converters:GreaterThanConverter x:Key="GreaterThanConverter" />
        </ResourceDictionary>
    </ContentPage.Resources>

    <ScrollView>
    <Grid RowDefinitions="*, Auto" Padding="40">

        <!-- Configuration Panel -->
        <Border Grid.Row="0"
                Margin="0,60,0,40"
                BackgroundColor="#1A2535" 
                StrokeThickness="1"
                Stroke="#2C3E50"
                Padding="40"
                HorizontalOptions="Center"
                VerticalOptions="Center"
                MaximumWidthRequest="600">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="12"/>
            </Border.StrokeShape>

            <VerticalStackLayout Spacing="30">
                
                <!-- Title -->
                <Label FontSize="24" 
                       FontFamily="AvantGardeDemi"
                       TextColor="#ECF0F1"
                       HorizontalOptions="Center">
                    <Label.FormattedText>
                        <FormattedString>
                            <Span Text="⚙ " FontSize="24"/>
                            <Span Text="Configuration de la simulation" FontFamily="AvantGardeDemi"/>
                        </FormattedString>
                    </Label.FormattedText>
                </Label>

                <!-- Agent Count Section -->
                <VerticalStackLayout Spacing="15">
                    <Label FontSize="18" 
                           FontFamily="AvantGardeDemi"
                           TextColor="#B0BEC5">
                        <Label.FormattedText>
                            <FormattedString>
                                <Span Text="👤 " FontSize="18"/>
                                <Span Text="Nombre d'agents" FontFamily="AvantGardeDemi"/>
                            </FormattedString>
                        </Label.FormattedText>
                    </Label>
                    
                    <Label Text="{Binding AgentCountDisplay}" 
                           FontSize="32" 
                           FontAttributes="Bold" 
                           TextColor="#3498DB"
                           HorizontalOptions="Center"
                           Margin="0,10"/>

                    <Slider Minimum="1" 
                            Maximum="1500" 
                            Value="{Binding SelectedAgentCount, Mode=TwoWay}"
                            MinimumTrackColor="#3498DB"
                            MaximumTrackColor="#ECF0F1"
                            ThumbColor="#3498DB"/>

                    <Grid ColumnDefinitions="*, *, *" Margin="0,5">
                        <Label Grid.Column="0" Text="1" FontSize="12" TextColor="#7F8C8D" HorizontalOptions="Start"/>
                        <Label Grid.Column="1" Text="750" FontSize="12" TextColor="#7F8C8D" HorizontalOptions="Center"/>
                        <Label Grid.Column="2" Text="1500" FontSize="12" TextColor="#7F8C8D" HorizontalOptions="End"/>
                    </Grid>
                </VerticalStackLayout>

                <!-- Political Split Section -->
                <VerticalStackLayout Spacing="15">
                    <Label FontSize="18" 
                           FontFamily="AvantGardeDemi"
                           TextColor="#B0BEC5">
                        <Label.FormattedText>
                            <FormattedString>
                                <Span Text="🏛️ " FontSize="18"/>
                                <Span Text="Répartition politique" FontFamily="AvantGardeDemi"/>
                            </FormattedString>
                        </Label.FormattedText>
                    </Label>

                    <!-- Barre de répartition visuelle -->
                    <Grid ColumnDefinitions="*, *" HeightRequest="36" ColumnSpacing="2">
                        <Border Grid.Column="0" BackgroundColor="#E74C3C">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="6,0,0,6"/>
                            </Border.StrokeShape>
                            <Label Text="{Binding LeftCountDisplay, StringFormat='◀ {0} Gauche'}"
                                   TextColor="White"
                                   FontFamily="AvantGardeDemi"
                                   FontSize="13"
                                   HorizontalOptions="Center"
                                   VerticalOptions="Center"/>
                        </Border>
                        <Border Grid.Column="1" BackgroundColor="#3498DB">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="0,6,6,0"/>
                            </Border.StrokeShape>
                            <Label Text="{Binding RightCountDisplay, StringFormat='Droite {0} ▶'}"
                                   TextColor="White"
                                   FontFamily="AvantGardeDemi"
                                   FontSize="13"
                                   HorizontalOptions="Center"
                                   VerticalOptions="Center"/>
                        </Border>
                    </Grid>

                    <Label Text="{Binding SplitDisplay}"
                           FontSize="13"
                           TextColor="#7F8C8D"
                           HorizontalOptions="Center"/>

                    <Slider Minimum="0"
                            Maximum="100"
                            Value="{Binding LeftPercentage, Mode=TwoWay}"
                            MinimumTrackColor="#E74C3C"
                            MaximumTrackColor="#3498DB"
                            ThumbColor="#2C3E50"/>

                    <Grid ColumnDefinitions="*, *, *" Margin="0,0">
                        <Label Grid.Column="0" Text="100% Gauche" FontSize="11" TextColor="#E74C3C" HorizontalOptions="Start"/>
                        <Label Grid.Column="1" Text="50 / 50" FontSize="11" TextColor="#7F8C8D" HorizontalOptions="Center"/>
                        <Label Grid.Column="2" Text="100% Droite" FontSize="11" TextColor="#3498DB" HorizontalOptions="End"/>
                    </Grid>

                    <!-- Préréglages de répartition -->
                    <Grid ColumnDefinitions="*, *, *, *, *" ColumnSpacing="6">
                        <Button Grid.Column="0" Text="100G" BackgroundColor="#E74C3C" TextColor="White" FontSize="11"
                                Clicked="OnSplitPresetClicked"/>
                        <Button Grid.Column="1" Text="70G" BackgroundColor="#C0392B" TextColor="White" FontSize="11"
                                Clicked="OnSplitPresetClicked"/>
                        <Button Grid.Column="2" Text="50/50" BackgroundColor="#7F8C8D" TextColor="White" FontSize="11"
                                Clicked="OnSplitPresetClicked"/>
                        <Button Grid.Column="3" Text="70D" BackgroundColor="#2980B9" TextColor="White" FontSize="11"
                                Clicked="OnSplitPresetClicked"/>
                        <Button Grid.Column="4" Text="100D" BackgroundColor="#3498DB" TextColor="White" FontSize="11"
                                Clicked="OnSplitPresetClicked"/>
                    </Grid>
                </VerticalStackLayout>

                <!-- Quick Presets -->
                <VerticalStackLayout Spacing="10">
                    <Label FontSize="14" 
                           FontFamily="AvantGardeDemi"
                           TextColor="#B0BEC5">
                        <Label.FormattedText>
                            <FormattedString>
                                <Span Text="⚡ " FontSize="14"/>
                                <Span Text="Préréglages rapides" FontFamily="AvantGardeDemi"/>
                            </FormattedString>
                        </Label.FormattedText>
                    </Label>

                    <Grid ColumnDefinitions="*, *, *" ColumnSpacing="10">
                        <Button Grid.Column="0" 
                                Text="200"
                                BackgroundColor="#95A5A6"
                                TextColor="White"
                                Clicked="OnPresetClicked"/>
                        <Button Grid.Column="1" 
                                Text="500"
                                BackgroundColor="#95A5A6"
                                TextColor="White"
                                Clicked="OnPresetClicked"/>
                        <Button Grid.Column="2" 
                                Text="800"
                                BackgroundColor="#95A5A6"
                                TextColor="White"
                                Clicked="OnPresetClicked"/>
                    </Grid>
                </VerticalStackLayout>

                <!-- Performance Warning -->
                <Border BackgroundColor="#2E2510" 
                        Padding="15" 
                        StrokeThickness="1" 
                        Stroke="#F39C12"
                        IsVisible="{Binding SelectedAgentCount, Converter={StaticResource GreaterThanConverter}, ConverterParameter=700}">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="6"/>
                    </Border.StrokeShape>
                    <HorizontalStackLayout Spacing="10">
                        <Label Text="⚠" FontSize="20" VerticalOptions="Center" TextColor="#F39C12"/>
                        <Label Text="Attention : Ralentissements à prévoir" 
                               FontFamily="AvantGardeBook"
                               FontSize="12" 
                               TextColor="#F5C342"
                               VerticalOptions="Center"
                               LineBreakMode="WordWrap"
                               MaximumWidthRequest="450"/>
                    </HorizontalStackLayout>
                </Border>

                <!-- Start Button -->
                <Button Text="▶ Démarrer la simulation" 
                        BackgroundColor="#27AE60" 
                        TextColor="White"
                        FontFamily="AvantGardeDemi"
                        FontSize="18"
                        Padding="20,15"
                        Margin="0,20,0,0"
                        Command="{Binding StartSimulationCommand}"/>

            </VerticalStackLayout>
        </Border>

        <!-- Footer -->
        <Label Grid.Row="2" 
               Text="VoxPopuli 4.0 - .NET 10 MAUI | Powered by ML.NET | © 2026 Leo-RD on GitHub " 
               FontSize="12" 
               TextColor="#95A5A6" 
               HorizontalOptions="Center"
               Margin="0,0,0,20"/>
    </Grid>
    </ScrollView>
</ContentPage>
